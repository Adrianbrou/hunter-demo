# =============================================================
# Hunter Demo: Environment Variables
# =============================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. (.gitignore already excludes it.)
# =============================================================

# Supabase
# From: Supabase Dashboard -> Project Settings -> Data API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# Service role key. KEEP PRIVATE. Used only in server contexts (scripts, never the browser).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic API key. Used by the Edge Function, set via:
#   npx supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# This local entry is for the simulate-logs script and local testing only.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Project ref for the Supabase CLI commands
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
